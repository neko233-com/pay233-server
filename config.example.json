      "provider": "stripe",
      "enabled": true,
      "options": {
        "mode": "adapter",
        "pay_url_base": "https://pay233.local/stripe/pay"
      }
    },
    {
      "name": "paypal",
      "provider": "paypal",
      "enabled": true,
      "options": {
        "mode": "adapter",
        "pay_url_base": "https://pay233.local/paypal/pay"
      }
